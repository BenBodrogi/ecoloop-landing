# Firebase Admin SDK — required for the waitlist API route
#
# How to get these values:
#   1. Go to Firebase Console → Project Settings → Service Accounts
#   2. Click "Generate new private key" → download the JSON file
#   3. Copy the three values below from that JSON
#
# On Vercel: add these in Project → Settings → Environment Variables.
# Paste FIREBASE_PRIVATE_KEY exactly as shown in the JSON (quotes and all).

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
